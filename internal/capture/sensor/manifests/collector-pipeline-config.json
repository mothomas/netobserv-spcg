{
  "log-level": "info",
  "metricsSettings": { "disableGlobalServer": true },
  "parameters": [
    {
      "name": "send",
      "write": {
        "type": "grpc",
        "grpc": {
          "targetHost": "{{TARGET_HOST}}",
          "targetPort": {{TARGET_PORT}}
        }
      }
    }
  ],
  "pipeline": [
    { "name": "send", "follows": "preset-ingester" }
  ]
}
